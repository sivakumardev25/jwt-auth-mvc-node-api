npm init -y
npm install express mongoose bcryptjs jsonwebtoken dotenv cors
npm install nodemon --save-dev


add in package.json =>>>  "dev": "nodemon App.js"

http://localhost:5004/api/user/get - get all users
http://localhost:5004/api/user/get/:id - get a user
http://localhost:5004/api/user/post - create a user
http://localhost:5004/api/user/put/:id - update a user
http://localhost:5004/api/user/delete/:id - delete a user